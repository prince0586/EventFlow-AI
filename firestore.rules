rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net: Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isVerified() && request.auth.uid == userId; }
    function isAdmin() { 
      return isVerified() && request.auth.token.email == "princeradadia@gmail.com"; 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===============================================================
    // Domain Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && 
                      isValidId(userId) &&
                      incoming().uid == request.auth.uid &&
                      incoming().email is string &&
                      incoming().email.size() < 256 &&
                      incoming().keys().hasAll(['uid', 'email']);
      allow update: if isOwner(userId) && 
                      incoming().uid == existing().uid &&
                      (
                        // Action: Update Profile
                        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'mobilityFirst', 'updatedAt'])
                      );
    }

    match /queues/{tokenId} {
      function isValidTokenSchema(data) {
        return data.keys().hasAll(['userId', 'venueId', 'serviceType', 'status', 'joinedAt']) &&
               data.userId == request.auth.uid &&
               data.venueId is string &&
               data.status in ['waiting', 'cancelled'] &&
               data.joinedAt is string;
      }

      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidId(tokenId) && isValidTokenSchema(incoming());
      allow update: if isVerified() && 
                      resource.data.userId == request.auth.uid && (
                        // Action: Cancel Token
                        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
                        incoming().status == 'cancelled'
                      ) || isAdmin();
    }

    match /venues/{venueId} {
      allow read: if true; // Public venue telemetry for map & list
      allow write: if isAdmin() && isValidId(venueId);
    }

    match /chats/{chatId}/messages/{messageId} {
      function isValidMessage(data) {
        return data.keys().hasAll(['userId', 'role', 'content', 'timestamp']) &&
               data.userId == request.auth.uid &&
               data.content is string && 
               data.content.size() <= 2000;
      }
      allow read: if isOwner(chatId) || isAdmin();
      allow create: if isOwner(chatId) && 
                      isValidId(chatId) &&
                      isValidId(messageId) &&
                      isValidMessage(incoming());
    }

    match /venue_analytics/{logId} {
      function isValidLog(data) {
        return data.keys().hasAll(['type', 'venueId', 'payload', 'timestamp']) &&
               data.type is string &&
               data.venueId is string &&
               data.payload is map;
      }
      allow create: if isVerified() && isValidId(logId) && isValidLog(incoming());
      allow read: if isAdmin();
    }
  }
}
