rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net: Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isVerified() && request.auth.uid == userId; }
    function isAdmin() { 
      return isVerified() && request.auth.token.email == "princeradadia@gmail.com"; 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===============================================================
    // Domain Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && 
                      incoming().uid == request.auth.uid &&
                      incoming().email is string &&
                      incoming().keys().hasAll(['uid', 'email']);
      allow update: if isOwner(userId) && 
                      incoming().uid == existing().uid &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'mobilityFirst']);
    }

    match /queues/{tokenId} {
      function isValidTokenSchema(data) {
        return data.keys().hasAll(['userId', 'venueId', 'serviceType', 'status', 'joinedAt']) &&
               data.userId == request.auth.uid &&
               data.status in ['waiting', 'cancelled'];
      }

      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidId(tokenId) && isValidTokenSchema(incoming());
      allow update: if isVerified() && 
                      resource.data.userId == request.auth.uid &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                      (incoming().status == 'cancelled' || isAdmin());
    }

    match /venues/{venueId} {
      allow read: if true; // Public venue telemetry for map & list
      allow write: if isAdmin();
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isOwner(chatId) || isAdmin();
      allow create: if isOwner(chatId) && 
                      incoming().userId == request.auth.uid &&
                      incoming().keys().hasAll(['userId', 'role', 'content', 'timestamp']);
    }

    match /venue_analytics/{logId} {
      allow create: if isVerified();
      allow read: if isAdmin();
    }
  }
}
